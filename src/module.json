{
    "id": "plaits",
    "name": "Plaits",
    "abbrev": "PL",
    "version": "0.4.0",
    "description": "Macro oscillator with 24 synthesis engines, based on Mutable Instruments Plaits",
    "author": "Emilie Gillet (port: charlesvestal)",
    "license": "MIT",
    "dsp": "dsp.so",
    "api_version": 2,
    "capabilities": {
        "audio_out": true,
        "audio_in": false,
        "midi_in": true,
        "midi_out": false,
        "chainable": true,
        "component_type": "sound_generator",
        "ui_hierarchy": {
            "levels": {
                "root": {
                    "label": "Plaits",
                    "knobs": [
                        "engine",
                        "harmonics",
                        "timbre",
                        "morph",
                        "decay",
                        "lpg_colour",
                        "fm_amount",
                        "aux_mix"
                    ],
                    "params": [
                        {
                            "key": "engine",
                            "label": "Engine",
                            "type": "enum",
                            "options": [
                                "VA VCF",
                                "Phase Dist",
                                "6-Op I",
                                "6-Op II",
                                "6-Op III",
                                "Wave Terr",
                                "Str Mach",
                                "Chiptune",
                                "V. Analog",
                                "Waveshape",
                                "FM",
                                "Grain",
                                "Additive",
                                "Wavetable",
                                "Chord",
                                "Speech",
                                "Swarm",
                                "Noise",
                                "Particle",
                                "String",
                                "Modal",
                                "Bass Drum",
                                "Snare Drum",
                                "Hi-Hat"
                            ],
                            "default": "VA VCF"
                        },
                        {
                            "key": "fm_preset",
                            "label": "FM Preset",
                            "type": "enum",
                            "options": [
                                "SOLID BASS", "Mooger Low", "LeaderTape", "MORHOL TB1",
                                "BASS    3", "BILL BASS", "BASS    1", "ELEC BASS",
                                "S.BAS 27.7", "RESONANCES", "SYN-BASS 2", "PRC SYNTH1",
                                "CROMA 2", "ANALOG  4", "ANALOG A", "ANALOG  6",
                                "CS 80", "INSERT 1", "SPIRAL", "DX-TROTT",
                                "GASHAUS", "RING DING", "PAPAGAYO", "WINEGLASS",
                                "AMYTAL", "FAIRLIGHT", "*PPG*Vol.1", "*PPG*Vol.2",
                                "*Fairl. 3", "*Vocoder 2", "*Sequence", "Bounce 4"
                            ],
                            "default": "SOLID BASS"
                        },
                        {
                            "key": "harmonics",
                            "label": "Harmonics",
                            "type": "float",
                            "min": 0.0,
                            "max": 1.0,
                            "default": 0.5,
                            "step": 0.02,
                            "unit": "%"
                        },
                        {
                            "key": "timbre",
                            "label": "Timbre",
                            "type": "float",
                            "min": 0.0,
                            "max": 1.0,
                            "default": 0.5,
                            "step": 0.02,
                            "unit": "%"
                        },
                        {
                            "key": "morph",
                            "label": "Morph",
                            "type": "float",
                            "min": 0.0,
                            "max": 1.0,
                            "default": 0.5,
                            "step": 0.02,
                            "unit": "%"
                        },
                        {
                            "key": "decay",
                            "label": "Decay",
                            "type": "float",
                            "min": 0.0,
                            "max": 1.0,
                            "default": 0.5,
                            "step": 0.02,
                            "unit": "%"
                        },
                        {
                            "key": "lpg_colour",
                            "label": "LPG Color",
                            "type": "float",
                            "min": 0.0,
                            "max": 1.0,
                            "default": 0.5,
                            "step": 0.02,
                            "unit": "%"
                        },
                        {
                            "key": "fm_amount",
                            "label": "FM",
                            "type": "float",
                            "min": 0.0,
                            "max": 1.0,
                            "default": 0.0,
                            "step": 0.02,
                            "unit": "%"
                        },
                        {
                            "key": "aux_mix",
                            "label": "Mix",
                            "type": "float",
                            "min": 0.0,
                            "max": 1.0,
                            "default": 0.0,
                            "step": 0.02,
                            "unit": "%"
                        },
                        {
                            "key": "timbre_mod",
                            "label": "Timbre Mod",
                            "type": "float",
                            "min": 0.0,
                            "max": 1.0,
                            "default": 0.0,
                            "step": 0.02,
                            "unit": "%"
                        },
                        {
                            "key": "morph_mod",
                            "label": "Morph Mod",
                            "type": "float",
                            "min": 0.0,
                            "max": 1.0,
                            "default": 0.0,
                            "step": 0.02,
                            "unit": "%"
                        },
                        {
                            "key": "legato",
                            "label": "Legato",
                            "type": "enum",
                            "options": ["off", "on"],
                            "default": "off"
                        },
                        {
                            "key": "velocity_sensitivity",
                            "label": "Vel Sens",
                            "type": "float",
                            "min": 0.0,
                            "max": 1.0,
                            "default": 0.5,
                            "step": 0.02,
                            "unit": "%"
                        },
                        {
                            "key": "octave_transpose",
                            "label": "Octave",
                            "type": "int",
                            "min": -3,
                            "max": 3,
                            "default": 0
                        }
                    ]
                }
            }
        }
    }
}
